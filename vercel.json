{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/functions/stripe-webhook", "destination": "/api/functions/stripe-webhook" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    },
    "api/functions/stripe-webhook.ts": {
      "maxDuration": 60
    }
  }
}
